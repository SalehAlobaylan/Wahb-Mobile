{
  "name": "wahb-mobile",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "description": "The native iOS and Android client for Wahb.",
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/geist-mono": "^0.4.3",
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@react-native-community/netinfo": "12.0.1",
    "@sentry/react-native": "~7.11.0",
    "@tanstack/react-query": "^5.101.2",
    "expo": "~57.0.7",
    "expo-asset": "~57.0.6",
    "expo-audio": "~57.0.2",
    "expo-battery": "~57.0.1",
    "expo-constants": "~57.0.6",
    "expo-crypto": "~57.0.1",
    "expo-dev-client": "~57.0.7",
    "expo-device": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-haptics": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-localization": "~57.0.1",
    "expo-router": "~57.0.7",
    "expo-secure-store": "~57.0.1",
    "expo-splash-screen": "~57.0.4",
    "expo-sqlite": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-video": "~57.0.1",
    "expo-web-browser": "~57.0.1",
    "i18next": "^26.3.6",
    "lucide-react-native": "^1.25.0",
    "react": "19.2.3",
    "react-i18next": "^17.0.10",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.10.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "29.5.14",
    "@types/node": "^26.1.1",
    "@types/react": "~19.2.2",
    "eslint": "^9.39.5",
    "eslint-config-expo": "~57.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~57.0.2",
    "prettier": "^3.9.5",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start --dev-client",
    "dev": "expo start --dev-client",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:maestro:list": "node scripts/list-maestro-flows.mjs",
    "test:maestro:smoke": "maestro test .maestro",
    "test:integration:local": "node scripts/test-local-integration.mjs",
    "hygiene:verify": "node scripts/verify-repository-hygiene.mjs",
    "doctor": "npx expo-doctor",
    "prebuild:clean": "expo prebuild --clean",
    "prebuild:verify": "expo prebuild --clean --no-install",
    "android:verify": "expo prebuild --clean --no-install && node scripts/verify-android-manifest.mjs",
    "release:verify": "expo prebuild --clean --no-install && node scripts/verify-release-config.mjs",
    "release:links:verify": "node scripts/verify-public-release-links.mjs",
    "validate": "npm run typecheck && npm run lint && npm run format:check && npm run hygiene:verify && npm test"
  },
  "engines": {
    "node": ">=22.13 <26"
  },
  "packageManager": "npm@11.9.0",
  "private": true,
  "license": "MIT",
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/\\.expo/"
    ]
  }
}
