# Use your Mac's LAN IP instead of localhost when running on a physical device.
EXPO_PUBLIC_CMS_URL=http://localhost:8080
EXPO_PUBLIC_IAM_URL=http://localhost:4003
# Sentry DSNs are public client identifiers, never authentication secrets.
# Leave empty to disable external crash diagnostics for a local build.
EXPO_PUBLIC_SENTRY_DSN=
